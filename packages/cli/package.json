{
  "name": "@logtide/cli",
  "version": "0.1.0",
  "description": "LogTide CLI — upload source maps and manage releases",
  "type": "module",
  "bin": {
    "logtide": "./dist/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/logtide-dev/logtide-javascript.git",
    "directory": "packages/cli"
  },
  "author": "Polliog <giuseppe@solture.it>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
